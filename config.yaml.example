llm:
  provider: dashscope
  api_key: ${DASHSCOPE_API_KEY:-your-api-key-here}
  model: your-model
  base_url: https://dashscope.aliyuncs.com
  max_tokens: 2048
  temperature: 0.7
  timeout: 60000
  # 思考模式（适用于 DeepSeek R1 等推理模型）
  thinking_enabled: true      # 是否启用思考模式（仅对支持思考模式的模型有效）
  reasoning_effort: high      # 思考强度：high（默认）/ max
tools:
  bash:
    enabled: true
    whitelist:
      - git
      - mvn
      - npm
      - docker
      - ls
      - cat
      - grep
      - find
    require_confirmation: true
  file:
    enabled: true
    allowed_paths:
      - .
    max_file_size: 10MB
    blocked_extensions:
      - .env
      - .pem
      - .key
      - .p12
      - .jks

session:
  auto_save: true
  max_history: 50
  # 注意：cli-history 现在自动按项目分组存储在 .hippo/projects/*/cli-history

ui:
  theme: dark
  prompt: "agent>"
  syntax_highlight: true
  show_token_usage: true
  show_timestamp: false
  color_output: true

context:
  policy: simple
  max_tokens: 30000
  # 兜底压缩策略
  tool_result:
    max_tokens: 2000
    truncate_strategy: tail

rule:
  # 规则文件支持分层加载，按优先级：
  # 1. 项目根目录: .hipporules, HIPPO.md
  # 2. 项目目录: .hippo/rules/*.md
  # 3. 用户全局: ~/.hippo/rules/*.md
  max_tokens: 8000             # Rule 最大 token 数
  inject_at_startup: true      # 启动时注入

cache:
  at_reference_enabled: true   # 启用 @ 引用
  max_refs_per_message: 5      # 单条消息最多引用文件数
  max_file_tokens: 4000        # 单文件最大 token 数
  cache_ttl_seconds: 300       # 文件缓存时间（秒）

index:
  enabled: true                # 启用代码索引
  max_results: 3               # 最大检索结果数
  max_tokens: 5000             # 检索结果最大 token 数

intent:
  enabled: true
  recognition:
    mode: hybrid                    # hybrid | rule | llm
    llm_enabled: true               # 是否启用 LLM 意图识别
    prefer_llm: false               # 是否优先使用 LLM
    high_confidence_threshold: 0.85 # 高置信度阈值
    low_confidence_threshold: 0.50  # 低置信度阈值
    fallback_to_rules: true         # 失败时回退到规则
  
planning:
  mode: composite                 # composite | simple | llm
  prefer_llm: false               # 是否优先使用 LLM 规划
  high_confidence_threshold: 0.85 # 高置信度阈值
  low_confidence_threshold: 0.50  # 低置信度阈值
  enable_complex_intent_detection: true  # 启用复杂意图检测

tokenizer:
  type: tiktoken        # tiktoken / simple
  model: gpt-4          # 模型名称
  cache_enabled: true   # 缓存开关
  cache_max_size: 1000  # 缓存最大条目数

session:
  persist_sessions: true      # 是否持久化会话
  max_saved_sessions: 50      # 最大保存会话数
  # 注意：现在自动按工作目录分组存储在 .hippo/projects/{hash}/sessions/
  # session_directory 配置已废弃，由 WorkspaceManager 自动管理
  auto_resume: true           # 启动时自动检查可恢复会话
  resume_timeout_hours: 72    # 超过 72 小时的会话自动标记为 IGNORED

# 长期记忆提取配置
# 开启后，系统会定期从对话中提取重要信息作为长期记忆保存
# 默认关闭，如需启用请设置 extraction_enabled: true
memory:
  extraction_enabled: false           # 启用长期记忆提取（默认关闭）
  extraction_interval: 5              # 每 N 轮对话触发一次提取
  session_extraction_enabled: true    # 启用会话内记忆提取（默认开启）

# LSP 语言服务器配置（高级代码理解能力）
# 启用后会获得 IDE 级别的代码理解能力：跳转到定义、查找引用、代码文档等
# 安装 jdtls: 下载 Eclipse JDT LS 并将 bin 目录加入 PATH
# 下载地址: https://download.eclipse.org/jdtls/milestones/
lsp:
  enabled: true               # 全局启用 LSP 功能（推荐启用！）
  
  servers:
    java:
      enabled: true
      # jdtls 启动命令（Windows 自动用 .bat，Linux/Mac 用 shell 脚本）
      command: jdtls
      args:
        - "-configuration"
        - "${user_home}/.jdtls/config"    # jdtls 配置目录（自动创建）
        - "-data"
        - "${user_home}/.jdtls/workspace" # jdtls 工作区（自动创建）
        # 可选：添加 JVM 参数调优
        # - "-vmargs"
        # - "-Xmx4G"
        # - "-XX:+UseG1GC"
      
      # 可选：环境变量配置
      # env:
      #   JAVA_HOME: /path/to/jdk-17+

# 💡 LSP 故障排查:
# 1. 确保 Java 版本 >= 17 (jdtls 要求)
# 2. 命令行输入 jdtls --version 能执行
# 3. 首次启动需要 60-120 秒建索引
# 4. Windows 用户: 确保 jdtls.bat 在 PATH 中
# 5. 有问题可设置 enabled: false 临时禁用
